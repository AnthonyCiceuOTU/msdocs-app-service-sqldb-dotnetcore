@{
    ViewData["Title"] = "Home";
}

<style>
    html,
    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .home-page {
        height: 100vh;
        width: 100%;
        box-sizing: border-box;
        overflow: hidden;
        background:
            radial-gradient(circle at top left, rgba(34, 197, 94, 0.08), transparent 30%),
            radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.08), transparent 30%),
            linear-gradient(135deg, #0b1020, #111827 50%, #0f172a);
        color: #e5e7eb;
        padding: 16px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .home-shell {
        max-width: 1100px;
        height: 100%;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
        min-height: 0;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 14px;
        flex-wrap: wrap;
        flex: 0 0 auto;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .brand-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(148, 163, 184, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: #f8fafc;
    }

    .brand-text h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #ffffff;
        line-height: 1.1;
    }

    .brand-text p {
        margin: 4px 0 0 0;
        color: #94a3b8;
        font-size: 0.95rem;
    }

    .panel,
    .unit-card {
        background: rgba(17, 24, 39, 0.88);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 18px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(12px);
    }

    .hero {
        padding: 18px;
        margin-bottom: 14px;
        flex: 0 0 auto;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1.35fr 0.85fr;
        gap: 18px;
        align-items: stretch;
    }

    .hero h2 {
        margin: 0 0 10px 0;
        font-size: 1.8rem;
        line-height: 1.15;
        color: #ffffff;
    }

    .hero p {
        margin: 0 0 14px 0;
        color: #94a3b8;
        font-size: 0.95rem;
        line-height: 1.5;
        max-width: 700px;
    }

    .hero-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-main,
    .btn-secondary,
    .lesson-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.2s ease;
        border: 1px solid rgba(255,255,255,0.08);
    }

    .btn-main {
        padding: 10px 16px;
        background: linear-gradient(135deg, #0ea5e9, #22c55e);
        color: white;
    }

    .btn-secondary {
        padding: 10px 16px;
        background: rgba(255,255,255,0.05);
        color: #e5e7eb;
    }

    .lesson-btn {
        padding: 8px 12px;
        background: rgba(255,255,255,0.05);
        color: #e5e7eb;
        white-space: nowrap;
    }

    .btn-main:hover,
    .btn-secondary:hover,
    .lesson-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.25);
        color: #ffffff;
    }

    .hero-stats {
        display: grid;
        gap: 10px;
    }

    .stat-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(148, 163, 184, 0.12);
        border-radius: 14px;
        padding: 14px;
    }

    .stat-card .label {
        color: #94a3b8;
        font-size: 0.8rem;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .stat-card .value {
        font-size: 1rem;
        font-weight: 600;
        color: #f8fafc;
    }

    .section-title {
        margin: 0 0 12px 0;
        font-size: 1.4rem;
        color: #ffffff;
        flex: 0 0 auto;
    }

    .units-grid {
        flex: 1 1 auto;
        min-height: 0;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .unit-card {
        overflow: hidden;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .unit-card-header {
        padding: 16px 16px 6px 16px;
    }

    .unit-number {
        color: #38bdf8;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 8px;
    }

    .unit-title {
        margin: 0;
        font-size: 1.2rem;
        color: #ffffff;
    }

    .unit-description {
        padding: 0 16px;
        color: #94a3b8;
        font-size: 0.88rem;
        line-height: 1.45;
        min-height: 54px;
    }

    .lesson-list {
        padding: 12px 16px 16px 16px;
        display: grid;
        gap: 10px;
        flex: 1 1 auto;
        min-height: 0;
    }

    .lesson-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border: 1px solid rgba(148, 163, 184, 0.14);
        border-radius: 12px;
        background: rgba(255,255,255,0.03);
    }

    .lesson-meta {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .lesson-name {
        color: #f8fafc;
        font-weight: 600;
        font-size: 0.92rem;
        line-height: 1.25;
    }

    .lesson-sub {
        color: #94a3b8;
        font-size: 0.76rem;
        line-height: 1.25;
    }

    @@media (max-width: 1100px) {
        .home-page {
            padding: 12px;
        }

        .hero h2 {
            font-size: 1.55rem;
        }

        .brand-text h1 {
            font-size: 1.7rem;
        }

        .unit-title {
            font-size: 1.05rem;
        }

        .lesson-name {
            font-size: 0.85rem;
        }

        .lesson-sub {
            font-size: 0.72rem;
        }

        .lesson-btn {
            padding: 7px 10px;
            font-size: 0.82rem;
        }
    }
</style>

<div class="home-page">
    <div class="home-shell">
        <div class="topbar">
            <div class="brand">
                <div class="brand-icon">&lt;/&gt;</div>
                <div class="brand-text">
                    <h1>Code Quest</h1>
                    <p>Learn programming one lesson at a time</p>
                </div>
            </div>

            <a asp-controller="Profile" asp-action="Index" class="btn-secondary">
                Profile
            </a>
        </div>

        <div class="panel hero">
            <div class="hero-grid">
                <div>
                    <h2>Build coding skills through structured lessons and hands-on practice.</h2>
                    <p>
                        Start from the beginning or jump into any lesson. Progress through units,
                        strengthen core programming concepts, and learn at your own pace.
                    </p>

                    <div class="hero-actions">
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="1" asp-route-lessonId="1" class="btn-main">
                            Start Learning
                        </a>

                        <a asp-controller="Profile" asp-action="Index" class="btn-secondary">
                            View Profile
                        </a>
                    </div>
                </div>

                <div class="hero-stats">
                    <div class="stat-card">
                        <div class="label">Current path</div>
                        <div class="value">Intro to Coding</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Units available</div>
                        <div class="value">3</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Recommended next lesson</div>
                        <div class="value">Unit 1 · Lesson 1</div>
                    </div>
                </div>
            </div>
        </div>

        <h2 class="section-title">Browse Units</h2>

        <div class="units-grid">
            <div class="unit-card">
                <div class="unit-card-header">
                    <div class="unit-number">Unit 1</div>
                    <h3 class="unit-title">Programming Basics</h3>
                </div>
                <div class="unit-description">
                    Learn what programming is, how logic works, and how to write your first instructions.
                </div>
                <div class="lesson-list">
                    <div class="lesson-item">
                        <div class="lesson-meta">
                            <div class="lesson-name">Lesson 1: What Is Coding?</div>
                            <div class="lesson-sub">Foundations and simple logic</div>
                        </div>
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="1" asp-route-lessonId="1" class="lesson-btn">
                            Open
                        </a>
                    </div>

                    <div class="lesson-item">
                        <div class="lesson-meta">
                            <div class="lesson-name">Lesson 2: Variables</div>
                            <div class="lesson-sub">Storing information in code</div>
                        </div>
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="1" asp-route-lessonId="2" class="lesson-btn">
                            Open
                        </a>
                    </div>

                    <div class="lesson-item">
                        <div class="lesson-meta">
                            <div class="lesson-name">Lesson 3: Conditions</div>
                            <div class="lesson-sub">Making decisions in a program</div>
                        </div>
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="1" asp-route-lessonId="3" class="lesson-btn">
                            Open
                        </a>
                    </div>
                </div>
            </div>

            <div class="unit-card">
                <div class="unit-card-header">
                    <div class="unit-number">Unit 2</div>
                    <h3 class="unit-title">Control Flow</h3>
                </div>
                <div class="unit-description">
                    Understand loops, repetition, and how programs follow sequences of steps.
                </div>
                <div class="lesson-list">
                    <div class="lesson-item">
                        <div class="lesson-meta">
                            <div class="lesson-name">Lesson 1: Loops</div>
                            <div class="lesson-sub">Repeat tasks efficiently</div>
                        </div>
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="2" asp-route-lessonId="1" class="lesson-btn">
                            Open
                        </a>
                    </div>

                    <div class="lesson-item">
                        <div class="lesson-meta">
                            <div class="lesson-name">Lesson 2: Nested Logic</div>
                            <div class="lesson-sub">Combining decisions and repetition</div>
                        </div>
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="2" asp-route-lessonId="2" class="lesson-btn">
                            Open
                        </a>
                    </div>

                    <div class="lesson-item">
                        <div class="lesson-meta">
                            <div class="lesson-name">Lesson 3: Debugging</div>
                            <div class="lesson-sub">Finding and fixing mistakes</div>
                        </div>
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="2" asp-route-lessonId="3" class="lesson-btn">
                            Open
                        </a>
                    </div>
                </div>
            </div>

            <div class="unit-card">
                <div class="unit-card-header">
                    <div class="unit-number">Unit 3</div>
                    <h3 class="unit-title">Functions and Structure</h3>
                </div>
                <div class="unit-description">
                    Break programs into reusable pieces and organize your code more clearly.
                </div>
                <div class="lesson-list">
                    <div class="lesson-item">
                        <div class="lesson-meta">
                            <div class="lesson-name">Lesson 1: Functions</div>
                            <div class="lesson-sub">Reusable blocks of code</div>
                        </div>
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="3" asp-route-lessonId="1" class="lesson-btn">
                            Open
                        </a>
                    </div>

                    <div class="lesson-item">
                        <div class="lesson-meta">
                            <div class="lesson-name">Lesson 2: Parameters</div>
                            <div class="lesson-sub">Passing data into functions</div>
                        </div>
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="3" asp-route-lessonId="2" class="lesson-btn">
                            Open
                        </a>
                    </div>

                    <div class="lesson-item">
                        <div class="lesson-meta">
                            <div class="lesson-name">Lesson 3: Return Values</div>
                            <div class="lesson-sub">Getting results back from functions</div>
                        </div>
                        <a asp-controller="Lessons" asp-action="Details" asp-route-unitId="3" asp-route-lessonId="3" class="lesson-btn">
                            Open
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>