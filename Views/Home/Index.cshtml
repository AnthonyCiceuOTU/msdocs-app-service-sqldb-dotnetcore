@{
    ViewData["Title"] = "Home";
}
@using System.Security.Claims
@{
    var isGuest = User.FindFirst("IsGuest")?.Value == "true";
}

<style>
    html,
    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .home-page {
        min-height: 100vh;
        width: 100%;
        box-sizing: border-box;
        overflow: hidden;
        background:
            radial-gradient(circle at top left, rgba(34, 197, 94, 0.08), transparent 30%),
            radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.08), transparent 30%),
            linear-gradient(135deg, #0b1020, #111827 50%, #0f172a);
        color: #e5e7eb;
        padding: 16px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .home-shell {
        max-width: 1100px;
        height: 100%;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .brand-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(148, 163, 184, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: #f8fafc;
    }

    .brand-text h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #ffffff;
        line-height: 1.1;
    }

    .brand-text p {
        margin: 4px 0 0 0;
        color: #94a3b8;
        font-size: 0.95rem;
    }

    .panel {
        background: rgba(17, 24, 39, 0.88);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 18px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(12px);
    }

    .hero {
        padding: 24px;
        margin-top: 8px;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1.35fr 0.85fr;
        gap: 18px;
        align-items: stretch;
    }

    .hero h2 {
        margin: 0 0 12px 0;
        font-size: 1.9rem;
        line-height: 1.15;
        color: #ffffff;
    }

    .hero p {
        margin: 0 0 18px 0;
        color: #94a3b8;
        font-size: 0.98rem;
        line-height: 1.6;
        max-width: 700px;
    }

    .hero-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-main,
    .btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.2s ease;
        border: 1px solid rgba(255,255,255,0.08);
        padding: 10px 16px;
    }

    .btn-main {
        background: linear-gradient(135deg, #0ea5e9, #22c55e);
        color: white;
    }

    .btn-secondary {
        background: rgba(255,255,255,0.05);
        color: #e5e7eb;
    }

    .btn-main:hover,
    .btn-secondary:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.25);
        color: #ffffff;
    }

    .hero-stats {
        display: grid;
        gap: 10px;
    }

    .stat-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(148, 163, 184, 0.12);
        border-radius: 14px;
        padding: 14px;
    }

    .stat-card .label {
        color: #94a3b8;
        font-size: 0.8rem;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .stat-card .value {
        font-size: 1rem;
        font-weight: 600;
        color: #f8fafc;
    }

    @@media (max-width: 900px) {
        .hero-grid {
            grid-template-columns: 1fr;
        }

        .hero h2 {
            font-size: 1.6rem;
        }

        .brand-text h1 {
            font-size: 1.7rem;
        }
    }
</style>

<div class="home-page">
    <div class="home-shell">
        <div class="topbar">
            <div class="brand">
                <div class="brand-icon">&lt;/&gt;</div>
                <div class="brand-text">
                    <h1>Code Quest</h1>
                    @*<p>Learn programming one lesson at a time</p>*@
                </div>
            </div>

            @if (isGuest)
            {
                <span class="btn-secondary" style="opacity:0.5; pointer-events:none;">
                    Profile
                </span>
            }
            else
            {
                <a asp-controller="Profile" asp-action="Index" class="btn-secondary">
                    Profile
                </a>
            }
        </div>

        <div class="panel hero">
            <div class="hero-grid">
                <div>
                    <h2>Build coding skills through structured lessons and hands-on practice.</h2>
                    <p>
                        Start from the beginning or browse all available units and lessons.
                        Learn at your own pace and move through the course in a clean, guided way.
                    </p>

                    <div class="hero-actions">
                        <a asp-controller="Lessons" asp-action="Start" class="btn-main">
                            Start Learning
                        </a>

                        <a asp-controller="Lessons" asp-action="Index" class="btn-secondary">
                            Browse Lessons
                        </a>

                        @*<a asp-controller="Profile" asp-action="Index" class="btn-secondary">
                            View Profile
                        </a>*@
                    </div>
                </div>

                <div class="hero-stats">
                    <div class="stat-card">
                        <div class="label">Current path</div>
                        <div class="value">Intro to Coding</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Learning mode</div>
                        <div class="value">Structured lessons</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Navigation</div>
                        <div class="value">Units and lessons</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>