@model DotNetCoreSqlDb.ViewModels.DataTypesViewModel

@{
    ViewData["Title"] = "Data Types";
}

<div class="container mt-4">
    <h1>Data Types</h1>
    <p class="text-success fw-bold">Completed</p>

    <div class="card mb-4">
        <div class="card-body">
            <h3>Introduction</h3>
            <p>
                Data types describe the kind of value being stored in a variable.
                Common examples include integers, decimals, text, and Boolean values.
            </p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h3>Example</h3>
            <pre class="bg-light p-3 border rounded">BEGIN
SET age = 16
SET name = "Sam"
DISPLAY name
END</pre>

            <h4>Explanation</h4>
            <p>
                In this example, <code>age</code> stores a number and <code>name</code> stores text.
                Different types of data are used for different purposes.
            </p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h3>Practice Exercises</h3>
            <p><strong>Practice:</strong> Store Text</p>
            <p>✏️ Fill in the Blank</p>

            <h4>Challenge</h4>
            <p>
                Complete the algorithm so the variable <code>name</code> stores the text Alex.
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.FeedbackMessage))
            {
                var alertClass = Model.IsCorrect == true ? "alert-success" :
                                 Model.IsCorrect == false ? "alert-danger" :
                                 "alert-info";

                <div class="alert @alertClass">
                    @Model.FeedbackMessage
                </div>
            }

            <form asp-action="DataTypes" asp-controller="UnitTwo" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-bold">Your Code</label>
                    <div class="bg-light p-3 border rounded font-monospace">
                        <div>BEGIN</div>
                        <div>
                            SET name =
                            <input asp-for="UserAnswer" class="form-control d-inline-block mx-1" style="width:180px;" />
                        </div>
                        <div>DISPLAY name</div>
                        <div>END</div>
                    </div>
                </div>

                <button type="submit" name="actionType" value="check" class="btn btn-primary me-2">
                    Check Solution
                </button>

                <button type="submit" name="actionType" value="hint" class="btn btn-warning me-2">
                    Hints
                </button>

                <button type="submit" name="actionType" value="solution" class="btn btn-secondary">
                    Solution
                </button>
            </form>

            @if (Model.ShowHint)
            {
                <div class="alert alert-warning mt-3">
                    Hint: text values are usually written in quotation marks.
                </div>
            }

            @if (Model.ShowSolution)
            {
                <div class="alert alert-secondary mt-3">
                    <strong>Solution:</strong>
                    <pre class="mt-2 mb-0">BEGIN
SET name = "Alex"
DISPLAY name
END</pre>
                </div>
            }
        </div>
    </div>

    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="UnitTwo" asp-action="ArithmeticExpressions">Unit Two, Lesson 3</a>
    </li>
</div>