@model DotNetCoreSqlDb.ViewModels.DecompositionViewModel

@{
    ViewData["Title"] = "Decomposition";
}

<div class="container mt-4">
    <h1>Decomposition</h1>
    <p class="text-success fw-bold">Completed</p>

    <div class="card mb-4">
        <div class="card-body">
            <h3>Introduction</h3>
            <p>
                Decomposition means breaking a large problem into smaller, manageable steps.
                This makes complex problems easier to solve.
            </p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h3>Example</h3>
            <pre class="bg-light p-3 border rounded">BEGIN
DISPLAY "Step 1: Choose destination"
DISPLAY "Step 2: Book transportation"
DISPLAY "Step 3: Pack luggage"
DISPLAY "Step 4: Travel"
END</pre>

            <h4>Explanation</h4>
            <p>
                Planning a trip is a large task, but by breaking it into smaller steps we can
                manage each part individually.
            </p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h3>Practice Exercises</h3>
            <p><strong>Practice:</strong> Break Down a Task</p>
            <p>✏️ Fill in the Blank</p>

            <h4>Challenge</h4>
            <p>
                Complete the steps for preparing for school in the morning.
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.FeedbackMessage))
            {
                var alertClass = Model.IsCorrect == true ? "alert-success" :
                                 Model.IsCorrect == false ? "alert-danger" :
                                 "alert-info";

                <div class="alert @alertClass">
                    @Model.FeedbackMessage
                </div>
            }

            <form asp-action="Decomposition" asp-controller="UnitOne" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-bold">Your Code</label>
                    <div class="bg-light p-3 border rounded font-monospace">
                        <div>BEGIN</div>
                        <div>
                            DISPLAY "Step 1:
                            <input asp-for="UserAnswer1" class="form-control d-inline-block mx-1" style="width:180px;" />
                            "
                        </div>
                        <div>
                            DISPLAY "Step 2:
                            <input asp-for="UserAnswer2" class="form-control d-inline-block mx-1" style="width:180px;" />
                            "
                        </div>
                        <div>
                            DISPLAY "Step 3:
                            <input asp-for="UserAnswer3" class="form-control d-inline-block mx-1" style="width:180px;" />
                            "
                        </div>
                        <div>DISPLAY "Step 4: Leave for school"</div>
                        <div>END</div>
                    </div>
                </div>

                <button type="submit" name="actionType" value="check" class="btn btn-primary me-2">
                    Check Solution
                </button>

                <button type="submit" name="actionType" value="hint" class="btn btn-warning me-2">
                    Hints
                </button>

                <button type="submit" name="actionType" value="solution" class="btn btn-secondary">
                    Solution
                </button>
            </form>

            @if (Model.ShowHint)
            {
                <div class="alert alert-warning mt-3">
                    Hint: think about what you usually do first, second, and third before you leave home.
                </div>
            }

            @if (Model.ShowSolution)
            {
                <div class="alert alert-secondary mt-3">
                    <strong>Solution:</strong>
                    <pre class="mt-2 mb-0">BEGIN
DISPLAY "Step 1: Wake up"
DISPLAY "Step 2: Get dressed"
DISPLAY "Step 3: Eat breakfast"
DISPLAY "Step 4: Leave for school"
END</pre>
                </div>
            }
        </div>
    </div>
</div>