@model DotNetCoreSqlDb.ViewModels.LessonsIndexViewModel

@{
    ViewData["Title"] = "Lessons";
}

<style>
    html,
    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .lessons-page {
        height: 100vh;
        width: 100%;
        box-sizing: border-box;
        overflow: hidden;
        background:
            radial-gradient(circle at top left, rgba(34, 197, 94, 0.08), transparent 30%),
            radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.08), transparent 30%),
            linear-gradient(135deg, #0b1020, #111827 50%, #0f172a);
        color: #e5e7eb;
        padding: 14px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .lessons-shell {
        max-width: 1500px;
        height: 100%;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 12px;
        flex-wrap: wrap;
        flex: 0 0 auto;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .brand-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(148, 163, 184, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: #f8fafc;
    }

    .brand-text h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #ffffff;
        line-height: 1.1;
    }

    .panel {
        background: rgba(17, 24, 39, 0.88);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 18px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(12px);
    }

    .lessons-hero {
        flex: 1 1 auto;
        min-height: 0;
        padding: 18px;
        display: grid;
        grid-template-rows: auto 1fr;
        gap: 16px;
        overflow: hidden;
    }

    .course-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .course-header h2 {
        margin: 0;
        font-size: 1.45rem;
        color: #ffffff;
    }

    .course-header p {
        margin: 4px 0 0 0;
        color: #94a3b8;
        font-size: 0.95rem;
    }

    .lessons-layout {
        min-height: 0;
        display: grid;
        grid-template-columns: 1.65fr 0.75fr;
        gap: 16px;
        overflow: hidden;
    }

    .units-panel,
    .lesson-content {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(148, 163, 184, 0.12);
        border-radius: 16px;
        padding: 16px;
        min-height: 0;
        overflow: hidden;
    }

    .units-panel {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .units-grid {
        flex: 1 1 auto;
        min-height: 0;
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        grid-auto-rows: 1fr;
        gap: 12px;
    }

    .unit-card {
        display: flex;
        flex-direction: column;
        min-height: 0;
        padding: 14px;
        border-radius: 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
    }

    .unit-title {
        color: #f8fafc;
        font-weight: 700;
        font-size: 0.98rem;
        margin-bottom: 6px;
        line-height: 1.3;
    }

    .unit-description {
        color: #94a3b8;
        font-size: 0.85rem;
        line-height: 1.4;
        margin-bottom: 8px;
    }

    .lesson-links {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-height: 0;
    }

    .lesson-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
        padding: 4px 9px;
        border-radius: 10px;
        text-decoration: none;
        color: #cbd5e1;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        transition: 0.2s ease;
        font-size: 0.8rem;
        line-height: 1.15;
        min-height: 28px;
        box-sizing: border-box;
    }

    .lesson-link:hover {
        color: #ffffff;
        border-color: rgba(34, 197, 94, 0.45);
        background: rgba(255,255,255,0.07);
        transform: translateY(-1px);
    }

    .lesson-link.current {
        border-color: rgba(14, 165, 233, 0.65);
        background: rgba(14, 165, 233, 0.12);
        color: #ffffff;
    }

    .lesson-link.completed {
        opacity: 0.98;
    }

    .lesson-status {
        font-weight: 700;
        color: #22c55e;
        flex: 0 0 auto;
        font-size: 0.85rem;
    }

    .lesson-content {
        display: grid;
        grid-template-rows: auto auto auto auto;
        gap: 14px;
        max-width: 560px;
        width: 100%;
        margin-left: auto;
        align-content: start;
    }

    .lesson-breadcrumb {
        color: #22c55e;
        margin-bottom: 10px;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .lesson-content h1 {
        margin: 0 0 10px 0;
        color: #ffffff;
        font-size: 1.9rem;
        line-height: 1.15;
    }

    .lesson-description {
        color: #94a3b8;
        margin-bottom: 0;
        line-height: 1.6;
    }

    .lesson-meta-card,
    .info-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 14px;
        padding: 14px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .info-card h3 {
        margin: 0 0 8px 0;
        color: #ffffff;
        font-size: 0.98rem;
    }

    .info-card p {
        margin: 0;
        color: #94a3b8;
        font-size: 0.88rem;
        line-height: 1.5;
    }

    .mini-label {
        color: #94a3b8;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 6px;
    }

    .mini-value {
        color: #f8fafc;
        font-size: 0.96rem;
        font-weight: 700;
    }

    .overview-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 14px;
        padding: 14px;
    }

    .overview-card h3 {
        margin: 0 0 8px 0;
        color: #ffffff;
        font-size: 0.98rem;
    }

    .overview-content {
        color: #94a3b8;
        font-size: 0.9rem;
        line-height: 1.55;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        max-height: 180px;
        overflow-y: auto;
        padding-right: 4px;
    }

    .empty-state h1 {
        color: #ffffff;
        margin-top: 0;
    }

    .empty-state p,
    .muted {
        color: #94a3b8;
    }

    .lesson-actions {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        align-items: stretch;
    }

    .nav-buttons {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        min-width: 0;
    }

    .complete-form {
        display: flex;
    }

    .btn-main,
    .btn-secondary,
    .btn-success,
    .btn-disabled {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.2s ease;
        border: 1px solid rgba(255,255,255,0.08);
        padding: 8px 12px;
        cursor: pointer;
        white-space: nowrap;
        font-size: 0.9rem;
        min-height: 40px;
        box-sizing: border-box;
        width: 100%;
    }

    .btn-main {
        background: linear-gradient(135deg, #0ea5e9, #22c55e);
        color: white;
    }

    .btn-secondary {
        background: rgba(255,255,255,0.05);
        color: #e5e7eb;
    }

    .btn-success {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        color: white;
    }

    .btn-disabled {
        background: rgba(255,255,255,0.03);
        color: #64748b;
        border-color: rgba(255,255,255,0.05);
        cursor: not-allowed;
        pointer-events: none;
    }

    .btn-main:hover,
    .btn-secondary:hover,
    .btn-success:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.25);
        color: #ffffff;
    }

    .topbar-btn {
        width: auto;
        min-width: 110px;
        padding: 10px 16px;
    }

    form {
        margin: 0;
    }

    @@media (max-width: 1300px) {
        .units-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }

        .lessons-layout {
            grid-template-columns: 1.5fr 0.8fr;
        }
    }

    @@media (max-width: 1100px) {
        .lessons-layout {
            grid-template-columns: 1fr;
        }

        .units-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .lesson-content {
            max-width: none;
            margin-left: 0;
        }
    }

    @@media (max-width: 800px) {
        html,
        body {
            overflow: auto;
        }

        .lessons-page {
            height: auto;
            min-height: 100vh;
            overflow: visible;
        }

        .lessons-shell,
        .lessons-hero {
            height: auto;
        }

        .units-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .lesson-content h1,
        .brand-text h1 {
            font-size: 1.6rem;
        }

        .info-grid,
        .lesson-actions {
            grid-template-columns: 1fr;
        }

        .complete-form {
            width: 100%;
        }
    }

    @@media (max-width: 560px) {
        .units-grid {
            grid-template-columns: 1fr;
        }

        .nav-buttons {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="lessons-page">
    <div class="lessons-shell">
        <div class="topbar">
            <div class="brand">
                <div class="brand-icon">&lt;/&gt;</div>
                <div class="brand-text">
                    <h1>Code Quest</h1>
                </div>
            </div>

            <a asp-controller="Home" asp-action="Index" class="btn-secondary topbar-btn">
                Home
            </a>
        </div>

        <div class="panel lessons-hero">
            <div class="course-header">
                <div>
                    <h2>Course Content</h2>
                    <p>Browse all units and preview any lesson before opening it.</p>
                </div>

                <a asp-controller="Lessons" asp-action="Start" class="btn-main" style="width:auto;">
                    Start Learning
                </a>
            </div>

            <div class="lessons-layout">
                <section class="units-panel">
                    @if (!Model.Units.Any())
                    {
                        <p class="muted">No lessons available yet.</p>
                    }
                    else
                    {
                        <div class="units-grid">
                            @foreach (var unit in Model.Units.OrderBy(u => u.SortOrder))
                            {
                                <div class="unit-card">
                                    <div class="unit-title">@unit.Title</div>

                                    @if (!string.IsNullOrWhiteSpace(unit.Description))
                                    {
                                        <div class="unit-description">@unit.Description</div>
                                    }

                                    <div class="lesson-links">
                                        @foreach (var lesson in unit.Lessons.OrderBy(l => l.SortOrder))
                                        {
                                            var cssClass = "lesson-link";
                                            if (lesson.IsCurrent) cssClass += " current";
                                            if (lesson.IsCompleted) cssClass += " completed";

                                            <a asp-controller="Lessons"
                                               asp-action="Index"
                                               asp-route-lessonId="@lesson.LessonId"
                                               class="@cssClass">
                                                <span>@lesson.Title</span>

                                                @if (lesson.IsCompleted)
                                                {
                                                    <span class="lesson-status">✓</span>
                                                }
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </section>

                <main class="lesson-content">
                    @if (Model.CurrentLessonId == null)
                    {
                        <div class="empty-state">
                            <h1>No lesson selected</h1>
                            <p>Select a lesson from the units panel or click Start Learning.</p>
                        </div>
                    }
                    else
                    {
                        <div class="lesson-meta-card">
                            <div class="lesson-breadcrumb">
                                @Model.CurrentUnitTitle
                            </div>

                            <h1>@Model.CurrentLessonTitle</h1>

                            @if (!string.IsNullOrWhiteSpace(Model.CurrentLessonDescription))
                            {
                                <p class="lesson-description">@Model.CurrentLessonDescription</p>
                            }
                        </div>

                        <div class="info-grid">
                            <div class="info-card">
                                <div class="mini-label">Status</div>
                                <div class="mini-value">
                                    @(Model.CurrentLessonCompleted ? "Completed" : "Not completed")
                                </div>
                            </div>

                            <div class="info-card">
                                <div class="mini-label">Navigation</div>
                                <div class="mini-value">
                                    @(Model.PreviousLessonId != null || Model.NextLessonId != null ? "Connected lesson path" : "Standalone selection")
                                </div>
                            </div>
                        </div>

                        <div class="overview-card">
                            <h3>Lesson Overview</h3>

                            @if (!string.IsNullOrWhiteSpace(Model.CurrentLessonContent))
                            {
                                <div class="overview-content">@Model.CurrentLessonContent</div>
                            }
                            else
                            {
                                <div class="overview-content">No lesson content available yet.</div>
                            }
                        </div>

                        <div class="lesson-actions">
                            <div class="nav-buttons">
                                @if (Model.PreviousLessonId != null)
                                {
                                    <a asp-controller="Lessons"
                                       asp-action="Index"
                                       asp-route-lessonId="@Model.PreviousLessonId"
                                       class="btn-secondary">
                                        ← Previous
                                    </a>
                                }
                                else
                                {
                                    <span class="btn-disabled">← Previous</span>
                                }

                                <a asp-controller="Lessons"
                                   asp-action="Open"
                                   asp-route-lessonId="@Model.CurrentLessonId"
                                   class="btn-main">
                                    Open Lesson
                                </a>

                                @if (Model.NextLessonId != null)
                                {
                                    <a asp-controller="Lessons"
                                       asp-action="Index"
                                       asp-route-lessonId="@Model.NextLessonId"
                                       class="btn-secondary">
                                        Next →
                                    </a>
                                }
                                else
                                {
                                    <span class="btn-disabled">Next →</span>
                                }
                            </div>

                            <form asp-controller="Lessons" asp-action="Complete" method="post" class="complete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="lessonId" value="@Model.CurrentLessonId" />

                                @if (Model.CurrentLessonCompleted)
                                {
                                    <button type="submit" class="btn-success">Completed ✓</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn-main">Mark Complete</button>
                                }
                            </form>
                        </div>
                    }
                </main>
            </div>
        </div>
    </div>
</div>