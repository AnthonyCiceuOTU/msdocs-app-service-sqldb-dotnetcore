@model Unit3DecisionMaking.ViewModels.IfElseViewModel

<div class="container mt-4">
    <h1>Lesson 13 — IF–ELSE</h1>

    <!-- INTRO -->
    <div class="card mb-4">
        <div class="card-body">
            <h3>Introduction</h3>
            <p>IF–ELSE statements allow a program to choose between two outcomes.</p>
            <p>If the condition is <strong>true</strong>, the IF block runs. Otherwise, the ELSE block runs.</p>
        </div>
    </div>

    <!-- EXAMPLE -->
    <div class="card mb-4">
        <div class="card-body">
            <h3>Example</h3>
            <pre class="bg-light p-3 border rounded">IF grade >= 50 THEN
    PRINT "Pass"
ELSE
    PRINT "Fail"
END IF</pre>
        </div>
    </div>

    <!-- QUIZ -->
    <div class="card mb-4">
        <div class="card-body">
            <h3>Practice & Quiz</h3>

            <form asp-action="IfElse" asp-controller="UnitThree" method="post">
                @Html.AntiForgeryToken()

                <!-- Q1 -->
                <div class="mb-4">
                    <label class="fw-bold">1. Write the condition for passing (grade is at least 50):</label>
                    <input asp-for="UserAnswer1" class="form-control" />

                    @if (Model.IsQ1Correct != null)
                    {
                        <div class="alert @(Model.IsQ1Correct == true ? "alert-success" : "alert-danger") mt-2">
                            @Model.Feedback1
                        </div>
                    }
                </div>

                <!-- Q2 -->
                <div class="mb-4">
                    <label class="fw-bold">2. What happens if the condition is FALSE?</label>

                    <input type="radio" asp-for="UserAnswer2" value="IF runs" /> IF runs<br />
                    <input type="radio" asp-for="UserAnswer2" value="ELSE runs" /> ELSE runs

                    @if (Model.IsQ2Correct != null)
                    {
                        <div class="alert @(Model.IsQ2Correct == true ? "alert-success" : "alert-danger") mt-2">
                            @Model.Feedback2
                        </div>
                    }
                </div>

                <!-- Q3 -->
                <div class="mb-4">
                    <label class="fw-bold">3. Fill in the blank:</label>
                    <pre class="bg-light p-2 border rounded">IF score >= 50 THEN
    PRINT "Pass"
____
    PRINT "Fail"</pre>

                    <input asp-for="UserAnswer3" class="form-control" placeholder="Enter keyword" />

                    @if (Model.IsQ3Correct != null)
                    {
                        <div class="alert @(Model.IsQ3Correct == true ? "alert-success" : "alert-danger") mt-2">
                            @Model.Feedback3
                        </div>
                    }
                </div>

                <!-- Q4 -->
                <div class="mb-4">
                    <label class="fw-bold">4. If grade = 40, what will print?</label>

                    <input type="radio" asp-for="UserAnswer4" value="Pass" /> Pass<br />
                    <input type="radio" asp-for="UserAnswer4" value="Fail" /> Fail

                    @if (Model.IsQ4Correct != null)
                    {
                        <div class="alert @(Model.IsQ4Correct == true ? "alert-success" : "alert-danger") mt-2">
                            @Model.Feedback4
                        </div>
                    }
                </div>

                <!-- BUTTONS -->
                <button type="submit" name="actionType" value="check" class="btn btn-primary me-2">
                    Check Answers
                </button>

                <button type="submit" name="actionType" value="hint" class="btn btn-warning me-2">
                    Hint
                </button>

                <button type="submit" name="actionType" value="solution" class="btn btn-secondary">
                    Solution
                </button>
            </form>

            <!-- HINT -->
            @if (Model.ShowHint)
            {
                <div class="alert alert-warning mt-3">
                    Think about what happens when the IF condition is false.
                </div>
            }

            <!-- SOLUTION -->
            @if (Model.ShowSolution)
            {
                <div class="alert alert-secondary mt-3">
                    <strong>Solutions:</strong>
                    <pre class="mt-2 mb-0">
1. grade >= 50
2. ELSE runs
3. ELSE
4. Fail
                    </pre>
                </div>
            }
        </div>
    </div>

    <!-- NAV -->
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="UnitThree" asp-action="NestedConditions">
            Unit 3, Lesson 14 — Nested Conditions
        </a>
    </li>
</div>