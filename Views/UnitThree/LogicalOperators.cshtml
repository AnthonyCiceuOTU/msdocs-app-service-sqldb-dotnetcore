

@* ============================= *@
@* Lesson 15 — Logical Operators *@
@model Unit3DecisionMaking.ViewModels.LogicalOperatorsViewModel

<div class="container mt-4">
    <h1>Logical Operators</h1>

    <p>Logical operators combine conditions (AND, OR, NOT).</p>

    <pre class="bg-light p-3 border rounded">IF age >= 18 AND citizen = true</pre>

    <form asp-action="LogicalOperators" asp-controller="UnitThree" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="UserAnswer" class="form-control mb-2" />
        <button type="submit" name="actionType" value="check" class="btn btn-primary">Check</button>
        <button type="submit" name="actionType" value="hint" class="btn btn-warning">Hint</button>
        <button type="submit" name="actionType" value="solution" class="btn btn-secondary">Solution</button>
    </form>
</div>
