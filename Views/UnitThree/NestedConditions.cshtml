@model DotNetCoreSqlDb.ViewModels.NestedConditionsViewModel

@{
    ViewData["Title"] = "Nested Conditions";
}

<style>
    html,
    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .lesson-page {
        min-height: 100vh;
        width: 100%;
        box-sizing: border-box;
        overflow: hidden;
        background:
            radial-gradient(circle at top left, rgba(34, 197, 94, 0.08), transparent 30%),
            radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.08), transparent 30%),
            linear-gradient(135deg, #0b1020, #111827 50%, #0f172a);
        color: #e5e7eb;
        padding: 16px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .lesson-shell {
        max-width: 1100px;
        height: 100%;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .brand-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(148, 163, 184, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: #f8fafc;
    }

    .brand-text h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #ffffff;
        line-height: 1.1;
    }

    .brand-text p {
        margin: 4px 0 0 0;
        color: #94a3b8;
        font-size: 0.95rem;
    }

    .panel {
        background: rgba(17, 24, 39, 0.88);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 18px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(12px);
    }

    .step-panel {
        flex: 1;
        min-height: 0;
        display: flex;
    }

    .step-card {
        width: 100%;
        padding: 18px 20px;
        display: none;
        overflow: hidden;
    }

    .step-card.active {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .step-top h2,
    .step-top h3 {
        margin: 0 0 8px 0;
        color: #ffffff;
        line-height: 1.15;
    }

    .step-top h2 {
        font-size: 1.65rem;
    }

    .step-top h3 {
        font-size: 1.3rem;
    }

    .step-top p {
        margin: 0 0 10px 0;
        color: #94a3b8;
        line-height: 1.5;
        font-size: 0.95rem;
    }

    .instruction-box {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(148, 163, 184, 0.12);
        border-radius: 14px;
        padding: 12px 14px;
        color: #cbd5e1;
        line-height: 1.5;
        font-size: 0.94rem;
        margin-bottom: 10px;
    }

    .code-block {
        background: rgba(2, 6, 23, 0.88);
        border: 1px solid rgba(148, 163, 184, 0.15);
        color: #e2e8f0;
        border-radius: 14px;
        padding: 12px 14px;
        font-family: Consolas, Monaco, monospace;
        white-space: pre-wrap;
        line-height: 1.45;
        font-size: 0.92rem;
        margin-bottom: 10px;
    }

    .concept-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin-top: 8px;
    }

    .concept-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(148, 163, 184, 0.12);
        border-radius: 12px;
        padding: 12px;
    }

    .concept-card h4 {
        margin: 0 0 6px 0;
        color: #ffffff;
        font-size: 0.95rem;
    }

    .concept-card p {
        margin: 0;
        color: #94a3b8;
        font-size: 0.88rem;
        line-height: 1.45;
    }

    .mc-grid {
        display: grid;
        gap: 10px;
    }

    .mc-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(148, 163, 184, 0.12);
        border-radius: 12px;
        padding: 10px 12px;
    }

    .mc-header {
        color: #e5e7eb;
        margin-bottom: 6px;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .text-input {
        width: 100%;
        box-sizing: border-box;
        background: rgba(2, 6, 23, 0.7);
        color: #f8fafc;
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 10px;
        padding: 10px 12px;
        outline: none;
        font-size: 0.92rem;
    }

    .text-input:focus {
        border-color: rgba(34, 197, 94, 0.5);
        box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.12);
    }

    .btn-main,
    .btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.2s ease;
        border: 1px solid rgba(255,255,255,0.08);
        padding: 10px 16px;
        cursor: pointer;
    }

    .btn-main {
        background: linear-gradient(135deg, #0ea5e9, #22c55e);
        color: white;
    }

    .btn-secondary {
        background: rgba(255,255,255,0.05);
        color: #e5e7eb;
    }

    .btn-main:hover,
    .btn-secondary:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.25);
        color: #ffffff;
    }

    .step-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 12px;
    }

    .step-progress {
        color: #94a3b8;
        font-size: 0.9rem;
    }

    .alert-box {
        border-radius: 12px;
        padding: 10px 12px;
        margin-top: 10px;
        border: 1px solid transparent;
        font-size: 0.92rem;
    }

    .alert-success-custom {
        background: rgba(34, 197, 94, 0.12);
        color: #bbf7d0;
        border-color: rgba(34, 197, 94, 0.2);
    }

    .alert-danger-custom {
        background: rgba(239, 68, 68, 0.12);
        color: #fecaca;
        border-color: rgba(239, 68, 68, 0.2);
    }

    .alert-info-custom {
        background: rgba(59, 130, 246, 0.12);
        color: #bfdbfe;
        border-color: rgba(59, 130, 246, 0.2);
    }

    .nav-footer {
        margin-top: 14px;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    @@media (max-width: 900px) {
        .brand-text h1 {
            font-size: 1.7rem;
        }

        .step-top h2 {
            font-size: 1.4rem;
        }

        .step-top h3 {
            font-size: 1.15rem;
        }

        .step-card {
            padding: 16px;
            overflow-y: auto;
        }

        .concept-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="lesson-page">
    <div class="lesson-shell">
        <div class="topbar">
            <div class="brand">
                <div class="brand-icon">&lt;/&gt;</div>
                <div class="brand-text">
                    <h1>Code Quest</h1>
                    <p>Unit 3 · Lesson 4</p>
                </div>
            </div>

            <a asp-controller="Lessons" asp-action="Index" class="btn-secondary">Browse Lessons</a>
        </div>

        <form asp-action="NestedConditions" asp-controller="UnitThree" method="post" id="lessonForm">
            @Html.AntiForgeryToken()

            <div class="panel step-panel">
                <div class="step-card active" id="step0">
                    <div class="step-top">
                        <h2>Nested Conditions</h2>
                        <p>
                            Nested conditions are conditions placed inside other conditions.
                            They help programs handle more detailed decision making.
                        </p>

                        <div class="code-block">IF grade >= 90 THEN
    PRINT "A"
ELSE IF grade >= 75 THEN
    PRINT "B"
ELSE IF grade >= 50 THEN
    PRINT "C"
ELSE
    PRINT "F"
END IF</div>

                        <div class="instruction-box">
                            In this lesson, you will work with a grading system that uses multiple thresholds.
                            First, identify the important grade ranges. Then explain why nested or chained
                            conditions are useful.
                        </div>

                        <div class="concept-grid">
                            <div class="concept-card">
                                <h4>Multiple Checks</h4>
                                <p>Nested conditions let a program test more than one possibility.</p>
                            </div>
                            <div class="concept-card">
                                <h4>Ordered Logic</h4>
                                <p>The program checks each condition in order until one matches.</p>
                            </div>
                            <div class="concept-card">
                                <h4>More Detail</h4>
                                <p>This structure is useful when there are several possible outcomes.</p>
                            </div>
                        </div>

                        @if (Model.ShowHint)
                        {
                            <div class="alert-box alert-info-custom">
                                Think about the main grade cutoffs used in the example, like top, middle, and passing ranges.
                            </div>
                        }

                        @if (Model.ShowSolution)
                        {
                            <div class="alert-box alert-info-custom">
                                A good answer includes multiple thresholds such as 90, 75, and 50.
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.FeedbackMessage) && Model.IsCorrect != null)
                        {
                            <div class="alert-box @(Model.IsCorrect == true ? "alert-success-custom" : "alert-danger-custom")">
                                @Model.FeedbackMessage
                            </div>
                        }
                    </div>

                    <div class="step-actions">
                        <div class="step-progress">Instructions</div>
                        <button type="button" class="btn-main" onclick="showStep(1)">Next</button>
                    </div>
                </div>

                <div class="step-card" id="step1">
                    <div class="step-top">
                        <h3>First assignment · Build the grade thresholds</h3>

                        <div class="instruction-box">
                            Write a short answer that includes the important grade thresholds for the grading system.
                            Make sure your answer shows multiple ranges.
                        </div>

                        <div class="mc-grid">
                            <div class="mc-card">
                                <div class="mc-header">Your threshold answer</div>
                                <input asp-for="UserAnswer" class="text-input" placeholder="Example: 90, 75, 50" />
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.FeedbackMessage) && Model.IsCorrect != null)
                        {
                            <div class="alert-box @(Model.IsCorrect == true ? "alert-success-custom" : "alert-danger-custom")">
                                @Model.FeedbackMessage
                            </div>
                        }
                    </div>

                    <div class="step-actions">
                        <button type="button" class="btn-secondary" onclick="showStep(0)">Back</button>
                        <div class="step-progress">Step 1 of 2</div>

                        @if (Model.IsCorrect == true)
                        {
                            <button type="button" class="btn-main" onclick="showStep(2)">Next</button>
                        }
                        else
                        {
                            <div style="display:flex; gap:10px; flex-wrap:wrap;">
                                <button type="submit" name="actionType" value="check" class="btn-main">Check</button>
                                <button type="submit" name="actionType" value="hint" class="btn-secondary">Hint</button>
                                <button type="submit" name="actionType" value="solution" class="btn-secondary">Solution</button>
                            </div>
                        }
                    </div>
                </div>

                <div class="step-card" id="step2">
                    <div class="step-top">
                        <h3>Second assignment · Explain nested conditions</h3>

                        <div class="instruction-box">
                            In one short sentence, explain why nested conditions are useful in programming.
                        </div>

                        <div class="mc-grid">
                            <div class="mc-card">
                                <div class="mc-header">Your explanation</div>
                                <input asp-for="ExplanationAnswer" class="text-input" placeholder="For now, type: multipleconditionsdifferentcasesorderedchecks" />
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.ExplanationFeedback))
                        {
                            <div class="alert-box @(Model.ExplanationCorrect == true ? "alert-success-custom" : "alert-danger-custom")">
                                @Model.ExplanationFeedback
                            </div>
                        }
                    </div>

                    <div class="step-actions">
                        <button type="button" class="btn-secondary" onclick="showStep(1)">Back</button>
                        <div class="step-progress">Step 2 of 2</div>

                        @if (Model.ExplanationCorrect == true)
                        {
                            <button type="submit" name="actionType" value="submit" class="btn-main">Submit Lesson</button>
                        }
                        else
                        {
                            <button type="submit" name="actionType" value="checkExplanation" class="btn-main">Check</button>
                        }
                    </div>
                </div>
            </div>
        </form>

        <div class="nav-footer">
            <a asp-controller="UnitThree" asp-action="IfElse" class="btn-secondary">Back to Lesson 3</a>
            <a asp-controller="Lessons" asp-action="Index" class="btn-main">Back to Lessons</a>
        </div>
    </div>
</div>

<script>
    function showStep(stepNumber) {
        document.querySelectorAll('.step-card').forEach(card => {
            card.classList.remove('active');
        });

        const target = document.getElementById(`step${stepNumber}`);
        if (target) {
            target.classList.add('active');
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        let stepToShow = 0;

        const firstDone = '@(Model.IsCorrect?.ToString() ?? "")';
        const explanationDone = '@(Model.ExplanationCorrect?.ToString() ?? "")';

        if (explanationDone === 'True') {
            stepToShow = 2;
        } else if (firstDone || @((Model.ShowHint || Model.ShowSolution).ToString().ToLower())) {
            stepToShow = 1;
        }

        showStep(stepToShow);
    });
</script>