

@* Lesson 12 — IF Statements *@

@model Unit3DecisionMaking.ViewModels.IfStatementViewModel

<div class="container mt-4">
    <h1>IF Statements</h1>

    <div class="card mb-4">
        <div class="card-body">
            <p>IF statements run code only when a condition is true.</p>
        </div>
    </div>

    <pre class="bg-light p-3 border rounded">IF temperature < 0 THEN
PRINT "Freezing"
END IF</pre>

    <form asp-action="IfStatements" asp-controller="UnitThree" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="UserAnswer" class="form-control mb-2" />
        <button type="submit" name="actionType" value="check" class="btn btn-primary">Check</button>
        <button type="submit" name="actionType" value="hint" class="btn btn-warning">Hint</button>
        <button type="submit" name="actionType" value="solution" class="btn btn-secondary">Solution</button>
    </form>
</div>
        <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="UnitThree" asp-action="IfElse">Unit 3, Lesson 3</a>
    </li>

